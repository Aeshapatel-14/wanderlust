<% layout("/layouts/boilerplate") %>
<div class="container">

  <div id="filters">

  <a href="/listings"
     class="filter <%= !category ? 'active' : '' %>">
    <i class="fa-solid fa-border-all"></i>
    <p>all</p>
  </a>

  <a href="/listings?category=trending"
     class="filter <%= category === 'trending' ? 'active' : '' %>">
    <i class="fa-solid fa-fire"></i>
    <p>trending</p>
  </a>

  <a href="/listings?category=rooms"
     class="filter <%= category === 'rooms' ? 'active' : '' %>">
    <i class="fa-solid fa-bed"></i>
    <p>rooms</p>
  </a>

  <a href="/listings?category=iconic-cities"
     class="filter <%= category === 'iconic-cities' ? 'active' : '' %>">
    <i class="fa-solid fa-mountain-city"></i>
    <p>iconic Cities</p>
  </a>

  <a href="/listings?category=mountains"
     class="filter <%= category === 'mountains' ? 'active' : '' %>">
    <i class="fa-solid fa-mountain"></i>
    <p>mountains</p>
  </a>

  <a href="/listings?category=castles"
     class="filter <%= category === 'castles' ? 'active' : '' %>">
    <i class="fa-brands fa-fort-awesome"></i>
    <p>castles</p>
  </a>

  <a href="/listings?category=amazing-pools"
     class="filter <%= category === 'amazing-pools' ? 'active' : '' %>">
    <i class="fa-solid fa-person-swimming"></i>
    <p>pools</p>
  </a>

  <a href="/listings?category=new"
     class="filter <%= category === 'new' ? 'active' : '' %>">
    <i class="fa-solid fa-key"></i>
    <p>new</p>
  </a>

  <a href="/listings?category=beachfront"
     class="filter <%= category === 'beachfront' ? 'active' : '' %>">
    <i class="fa-solid fa-umbrella-beach"></i>
    <p>beach</p>
  </a>

  <a href="/listings?category=camping"
     class="filter <%= category === 'camping' ? 'active' : '' %>">
    <i class="fa-solid fa-campground"></i>
    <p>camping</p>
  </a>

  <a href="/listings?category=farms"
     class="filter <%= category === 'farms' ? 'active' : '' %>">
    <i class="fa-solid fa-cow"></i>
    <p>farms</p>
  </a>

  <a href="/listings?category=arctic"
     class="filter <%= category === 'arctic' ? 'active' : '' %>">
    <i class="fa-solid fa-snowflake"></i>
    <p>arctic</p>
  </a>

  <!-- TAX TOGGLE -->
  <div class="tax-toggle">
    <div class="form-check form-switch">
      <input class="form-check-input"
             type="checkbox"
             role="switch"
             id="switchCheckDefault">

      <label class="form-check-label" for="switchCheckDefault">
        Display total after taxes
      </label>
    </div>
  </div>

</div>

  <div class="row row-cols-lg-5 row-cols-md-4 row-cols-sm-3 g-4 mt-3">
    
    <% for(let listing of allListings){ %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="col">
        <div class="card">
            <img 
            src="<%= listing.image ? listing.image.url : '/images/default.jpg' %>" 
            class="card-img-top listing-img" alt="listing_image">
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
                <b><%= listing.title %></b><br>
                &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>
                <i class="tax-info">&nbsp;&nbsp; +15% GST</i>
              </p>
            </div>
          </div>

        </div>
      </a>
    <% } %>

  </div>

</div>

